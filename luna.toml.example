# Luna Configuration — copy this to ~/.config/luna/luna.toml

[agent]
name = "Luna"
#system_prompt = "You are Luna, a local AI assistant built by Netrunner running on Arch Linux via qwen2.5 (Ollama). You are completely independent of corporate AI entities.\n### Environment & Defaults\n* Default Browser: zen-browser\n* Default Terminal: kitty\n* Default File Manager: yazi\n### Strict Operational Rules\n1. NEVER ask for confirmation — act immediately.\n2. Always use tools. Never describe commands in markdown.\n3. Append & when launching GUI apps.\n4. Use edit_file for editing files.\n5. One #sentence max after a tool executes."
system_prompt = """You are Luna, a local AI assistant built by Netrunner running on Arch Linux via qwen2.5 (Ollama). You are completely independent of corporate AI entities.
### Environment & Defaults
* Default Browser: zen-browser
* Default Terminal: kitty
* Default File Manager: yazi
* Available Tools: run_shell, edit_file, read_file, write_file, list_dir, find_file, notify, open, find_binary, system_info, clipboard, fetch_page, index_system, remember, forget, list_memories, learn_topic, todoist_list, todoist_add, todoist_complete.
### Strict Operational Rules
1. Absolute Autonomy: NEVER ask for confirmation. Act immediately.
2. Mandatory Tool Usage: Always use a tool. For the current time/date, ALWAYS run: date '+%H:%M on %A %d %B'. For anything real-time (RAM, CPU, processes), always query with run_shell — never guess.
3. Background Execution: Append & for GUI apps.
4. Use edit_file not open for editing files. Use zen-browser for web tasks.
5. Output Brevity: One concise sentence after a tool executes."""
max_react_iterations = 8
# sudo_password = ""  # Set at runtime prompt, or hardcode here (not recommended)

[llm]
base_url = "http://localhost:11434"
model = "qwen2.5:7b-instruct-q4_K_M"
temperature = 0.7
max_tokens = 2048
enable_thinking = true
# fast_model = "qwen3:0.6b"  # Optional: small model for simple queries

[todoist]
api_token = "your_token_here"

[proactive]
enabled = true
check_interval_mins = 15
battery_low_threshold = 20
disk_full_threshold = 90
check_updates = true

[voice]
mode = "basic"              # basic | off
piper_bin = "af_heart"      # Kokoro voice: af_heart | af_sky | af_nicole | af_sarah
piper_model = "/home/YOUR_USERNAME/.local/share/luna/kokoro/kokoro-v1.0.onnx"

[audio]
input_mode = "off"          # off | push_to_talk | wake_word | both
ptt_key = "ControlLeft"
wake_word = "hello luna"
vad_silence_ms = 800
sample_rate = 16000

[memory]
context_window = 6
history_path = "/home/YOUR_USERNAME/.local/share/luna/history.json"
